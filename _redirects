# Cloudflare Pages redirects
# Format: source destination status
# UWAGA: Cloudflare Pages automatycznie 308-redirektuje *.html → bez .html.
# Targets podajemy BEZ .html żeby uniknąć łańcucha 301 → 308.

# === LEGACY URLs ze starej wersji strony (Lovable build, sezon 2025) ===
# Cloudflare cache nadal serwuje stare pliki — przy najbliższym deploy 301 nadpisuje.
/krakow              /lokalizacje/krakow      301
/krakow/             /lokalizacje/krakow      301
/krakow.html         /lokalizacje/krakow      301
/jedrzejow           /lokalizacje/jedrzejow   301
/jedrzejow/          /lokalizacje/jedrzejow   301
/jedrzejow.html      /lokalizacje/jedrzejow   301
/kielce              /lokalizacje/kielce      301
/kielce/             /lokalizacje/kielce      301
/kielce.html         /lokalizacje/kielce      301
/eventy-firmowe      /eventy/event-firmowy    301
/eventy-firmowe/     /eventy/event-firmowy    301
/eventy-firmowe.html /eventy/event-firmowy    301

# === Stary URL "oferta" indeksowany przez Google z poprzedniej wersji ===
/oferta              /cennik                  301
/oferta/             /cennik                  301
/oferta.html         /cennik                  301

